# Service
PORT=8791
PUBLIC_BASE_URL=https://paperclip-d0sw.srv1628724.hstgr.cloud
BRIDGE_BASE_PATH=/google-calendar
BRIDGE_API_TOKEN=change-me-long-random-token

# Google OAuth Web Application credentials
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret
GOOGLE_REDIRECT_URI=https://paperclip-d0sw.srv1628724.hstgr.cloud/google-calendar/oauth/callback

# Comma-separated scopes. Start read-only; add calendar.events when writes are needed.
GOOGLE_SCOPES=https://www.googleapis.com/auth/calendar.readonly

# Token storage. For production: mount a persistent host path here.
TOKEN_DIR=/data/tokens
TOKEN_FILE=google-calendar-token.json

# Optional hardening
ALLOWED_GOOGLE_EMAIL=
