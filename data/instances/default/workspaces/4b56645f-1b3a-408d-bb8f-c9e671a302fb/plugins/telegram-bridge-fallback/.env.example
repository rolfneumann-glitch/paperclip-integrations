# Required: set via secret channel only (do not commit real value)
TELEGRAM_BOT_TOKEN=
PAPERCLIP_WEBHOOK_TOKEN=

# Optional hardening: restrict allowed chat
TELEGRAM_ALLOWED_CHAT_ID=
TELEGRAM_NOTIFY_CHAT_ID=
TELEGRAM_NOTIFY_STATUSES=todo,in_progress,in_review,done
TELEGRAM_SEND_MAX_RETRIES=2
TELEGRAM_SEND_RETRY_BACKOFF_MS=250

# Optional endpoint path for webhook-style integrations
TELEGRAM_WEBHOOK_PATH=/telegram/webhook
# Comma-separated optional aliases (for reverse-proxy path rewrites)
TELEGRAM_WEBHOOK_PATH_ALIASES=
TELEGRAM_WEBHOOK_SECRET_TOKEN=
PAPERCLIP_ISSUE_EVENT_PATH=/paperclip/issues/events
PAPERCLIP_CEO_FORWARD_URL=
PAPERCLIP_CEO_FORWARD_TOKEN=
PAPERCLIP_CEO_FORWARD_TIMEOUT_MS=5000

# Optional hardening: only accept requests with these Host / X-Forwarded-Host values
# Comma-separated values, include port where applicable (example: example.com,76.13.48.145:55035)
PAPERCLIP_ALLOWED_HOSTNAMES=
